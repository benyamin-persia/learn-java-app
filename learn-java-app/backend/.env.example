# Copy to .env and fill in values
PORT=5000

# MongoDB: local or Atlas (replace <db_password> with your Atlas user password)
# Atlas example: mongodb+srv://12q3wa4esz:<db_password>@cluster0.nsiny.mongodb.net/learn-java?appName=Cluster0
MONGODB_URI=mongodb://localhost:27017/learn-java

# Required for JWT auth; use a long random string in production
JWT_SECRET=your-secret-key-change-in-production
# Optional: token expiry (default 7d)
# JWT_EXPIRES_IN=7d
